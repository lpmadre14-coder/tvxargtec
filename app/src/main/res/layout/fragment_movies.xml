<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Featured Banner -->
            <FrameLayout
                android:id="@+id/featuredBanner"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/bg_secondary">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_gradient_hero" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Película Destacada"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="2024 · Acción · 2h 15min"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWatchFeatured"
                        style="@style/Widget.Tvxargtec.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:layout_marginTop="12dp"
                        android:text="Ver Ahora" />

                </LinearLayout>

            </FrameLayout>

            <!-- Genre Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/genreContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAll"
                        style="@style/Widget.Tvxargtec.Chip.Selected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Todos" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAction"
                        style="@style/Widget.Tvxargtec.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Acción" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipComedy"
                        style="@style/Widget.Tvxargtec.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Comedia" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDrama"
                        style="@style/Widget.Tvxargtec.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Drama" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHorror"
                        style="@style/Widget.Tvxargtec.Chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Terror" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Movies Grid -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvMovies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:padding="12dp"
                    android:paddingBottom="80dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="2" />

                <!-- Loading -->
                <FrameLayout
                    android:id="@+id/loadingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:gravity="center"
                    android:visibility="visible">

                    <ProgressBar
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:indeterminateTint="@color/brand_violet" />

                </FrameLayout>

            </FrameLayout>

        </LinearLayout>

    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
