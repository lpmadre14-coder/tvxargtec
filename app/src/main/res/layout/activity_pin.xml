<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_lock"
        android:tint="@color/brand_violet" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Acceso Protegido"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ingresa tu PIN de 6 dígitos"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etPin1"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPin2"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPin3"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPin4"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPin5"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPin6"
            android:layout_width="48dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_pin_box"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvPinError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="PIN incorrecto. Intenta de nuevo."
        android:textColor="@color/semantic_error"
        android:textSize="13sp"
        android:visibility="gone" />

</LinearLayout>
